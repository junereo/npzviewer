{
  "name": "lyra-trajectory-gui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@playcanvas/splat-transform": "^2.5.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "multer": "^2.0.2",
    "playcanvas": "^2.19.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.6.0",
    "three": "^0.182.0",
    "tsx": "^4.21.0",
    "vite": "^8.0.16",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
